# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role : uniquement côté serveur (webhook, admin)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── YouSign API v3 ────────────────────────────────────────────────────────────
# Sandbox : https://api-sandbox.yousign.app/v3
# Production : https://api.yousign.app/v3
YOUSIGN_API_BASE_URL=https://api-sandbox.yousign.app/v3
YOUSIGN_API_KEY=your-yousign-api-key-sandbox
YOUSIGN_WEBHOOK_SECRET=your-yousign-webhook-secret

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=notifications@votre-domaine.fr

# ── App ───────────────────────────────────────────────────────────────────────
# URL publique de l'app (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
